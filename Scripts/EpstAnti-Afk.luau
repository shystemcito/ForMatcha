            reached = false
            local newPos = Vector2.new(currentPos.X +(dx/distance)*speed,currentPos.Y +(dy/distance)*speed)
            local delta = newPos - currentPos
            currentPos = newPos
            Image1.Position = Image1.Position + delta
        end
    end
